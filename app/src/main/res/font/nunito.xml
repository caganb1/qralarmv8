<?xml version="1.0" encoding="utf-8"?>
<!--
  Downloadable Font: Nunito from Google Fonts.
  Requires: Google Play Services (GMS) on device.
  If GMS is unavailable the system falls back to sans-serif-medium automatically.
-->
<font-family xmlns:app="http://schemas.android.com/apk/res-auto"
    app:fontProviderAuthority="com.google.android.gms.fonts"
    app:fontProviderPackage="com.google.android.gms"
    app:fontProviderQuery="name=Nunito&amp;weight=400"
    app:fontProviderCerts="@array/com_google_android_gms_fonts_certs">
</font-family>

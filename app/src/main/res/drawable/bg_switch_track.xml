<?xml version="1.0" encoding="utf-8"?>
<!-- Apple-style pill track: vibrant green when ON, soft grey when OFF -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/switch_on_track"/>
            <corners android:radius="16dp"/>
            <size
                android:width="52dp"
                android:height="32dp"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/switch_off_track"/>
            <corners android:radius="16dp"/>
            <size
                android:width="52dp"
                android:height="32dp"/>
        </shape>
    </item>
</selector>

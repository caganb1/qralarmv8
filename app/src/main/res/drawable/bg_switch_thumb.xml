<?xml version="1.0" encoding="utf-8"?>
<!-- Smooth white oval thumb with a soft 1dp grey stroke (Dieter Rams style) -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="@color/switch_thumb"/>
    <stroke
        android:width="1dp"
        android:color="@color/switch_thumb_stroke"/>
    <size
        android:width="28dp"
        android:height="28dp"/>
</shape>

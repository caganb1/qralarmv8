<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Red top bar — Bauhaus horizontal stripe -->
    <View
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:background="@color/accent"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="32dp">

        <!-- Blue geometric block with time -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/primary"
            android:paddingVertical="28dp"
            android:paddingHorizontal="24dp">

            <TextView
                android:id="@+id/tv_ring_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textColor="@color/white"
                android:textSize="72sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.05"
                android:text="00:00"/>
        </FrameLayout>

        <!-- Yellow label stripe -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/accent_yellow"
            android:paddingVertical="10dp"
            android:paddingHorizontal="24dp">
            <TextView
                android:id="@+id/tv_ring_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold"
                android:text=""/>
        </FrameLayout>

        <View android:layout_width="match_parent" android:layout_height="2dp"
              android:background="@color/black" android:layout_marginTop="32dp"/>

        <TextView
            android:id="@+id/tv_ring_instruction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="16dp"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textAlignment="center"
            android:text="@string/scan_to_dismiss"/>

        <TextView
            android:id="@+id/tv_ring_qr_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="6dp"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:textAlignment="center"
            android:textStyle="bold"
            android:visibility="gone"/>

    </LinearLayout>

    <!-- Bottom action area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingBottom="32dp"
        android:paddingTop="16dp">

        <View android:layout_width="match_parent" android:layout_height="2dp"
              android:background="@color/black" android:layout_marginBottom="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_scan_qr"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="@string/scan_button"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:textColor="@color/white"
            app:backgroundTint="@color/accent"
            app:icon="@drawable/ic_qr_code"
            app:iconTint="@color/white"
            app:iconGravity="textStart"
            app:cornerRadius="0dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_dismiss_no_qr"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="@string/dismiss_no_qr"
            android:visibility="gone"
            android:textColor="@color/black"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:strokeColor="@color/black"
            app:strokeWidth="2dp"
            app:cornerRadius="0dp"/>
    </LinearLayout>

    <!-- Bottom black bar -->
    <View android:layout_width="match_parent" android:layout_height="8dp"
          android:background="@color/black"/>

</LinearLayout>

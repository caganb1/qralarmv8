<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:gravity="center"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/routine_intro"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="6dp"/>

    <TextView
        android:id="@+id/tv_routine_active_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="48dp"
        android:gravity="center"
        tools:text="Cilt bakımı"/>

    <com.qralarm.app.CircularCountdownView
        android:id="@+id/countdown_view"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_marginBottom="56dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_routine_done"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/routine_done_skip"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        app:backgroundTint="@color/text_primary"
        app:cornerRadius="28dp"/>

</LinearLayout>
